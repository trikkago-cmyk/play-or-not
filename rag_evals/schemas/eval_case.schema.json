{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/rag_evals/eval_case.schema.json",
  "title": "RAG Eval Case",
  "description": "Single JSONL record for retrieval evaluation.",
  "type": "object",
  "required": ["id", "query", "expected"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "description": "Business mode (e.g. referee/recommendation)."
    },
    "category": {
      "type": "string",
      "description": "Category label used in metric breakdown."
    },
    "active_game_id": {
      "type": "string",
      "description": "Current referee game id for game-scoped retrieval."
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "expected": {
      "type": "object",
      "required": ["must_game_ids", "keyword_groups"],
      "properties": {
        "must_game_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Each id is counted as one retrieval target."
        },
        "any_game_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "The whole list is treated as one OR target; matching any one game id counts."
        },
        "keyword_groups": {
          "type": "array",
          "description": "Each group is OR semantics; one matched keyword in group counts as one target.",
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "min_recall_at_k": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Optional per-case pass threshold override."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
